# ─── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://houseduty:houseduty_secret@localhost:5432/houseduty"

# ─── Auth ──────────────────────────────────────────────────
JWT_SECRET="change_me_in_production_use_32_chars_min"
JWT_EXPIRES_IN="7d"

# ─── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_URL="http://localhost:5173"

# ─── Photo Storage ─────────────────────────────────────────
# Options: local | s3 | supabase
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads

# S3 / R2 (when STORAGE_PROVIDER=s3)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=        # for Cloudflare R2 / MinIO

# Supabase (when STORAGE_PROVIDER=supabase)
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# SUPABASE_BUCKET=houseduty-photos

# ─── Redis (optional — for offline sync queue) ─────────────
REDIS_URL="redis://localhost:6379"

# ─── Photo Retention (days) ────────────────────────────────
PHOTO_RETENTION_DAYS=30
